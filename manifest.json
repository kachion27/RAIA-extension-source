{
   "action": {
      "default_icon": {
         "16": "icons/icon.png",
         "32": "icons/icon.png"
      },
      "default_popup": "popup/popup.html",
      "default_title": "Raia"
   },
   "background": {
      "service_worker": "background/background.js"
   },
   "description": "Raia browser extension for Chromium and Gecko",
   "host_permissions": [ "http://localhost:4111/*", "https://api-v3.raia.edu.vn/*" ],
   "icons": {
      "128": "icons/icon.png",
      "16": "icons/icon.png",
      "48": "icons/icon.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Raia Extension",
   "options_ui": {
      "open_in_tab": true,
      "page": "auth/auth.html"
   },
   "permissions": [ "storage", "tabs", "alarms" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.0"
}
